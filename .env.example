# Database Configuration
# PostgreSQL connection string for Supabase
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA

# Supabase PostgreSQL (replace with your actual connection string)
DATABASE_URL="postgresql://postgres:password@db.example.com:5432/postgres?schema=public"

