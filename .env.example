# Database Configuration
# PostgreSQL connection string.
# Do not use file:./dev.db or SQLite. This app uses @prisma/adapter-pg.

# Local Docker PostgreSQL from `npm run db:dev:up`
DATABASE_URL="postgresql://bluearc:bluearc@localhost:5432/bluearc_os?schema=public"

# Supabase PostgreSQL example
# DATABASE_URL="postgresql://postgres:password@db.example.com:5432/postgres?schema=public"

# Direct connection (optional, for migration workflows)
# DIRECT_URL="postgresql://postgres:password@db.example.com:5432/postgres?schema=public"
