# Database Configuration
# PostgreSQL connection string.
# Do not use file:./dev.db or SQLite. This app uses @prisma/adapter-pg.

# Local Docker PostgreSQL from `npm run db:dev:up`
DATABASE_URL="postgresql://bluearc:bluearc@localhost:5432/bluearc_os?schema=public"

# Supabase PostgreSQL example
# DATABASE_URL="postgresql://postgres:password@db.example.com:5432/postgres?schema=public"

# Direct connection (optional, for migration workflows)
# DIRECT_URL="postgresql://postgres:password@db.example.com:5432/postgres?schema=public"

# AI providers (server-side only; Settings stores references to these names, not raw keys)
# Local OpenAI-compatible endpoint, for LM Studio/Ollama/vLLM/llama.cpp.
# This is tried before paid providers when configured in Settings.
# LOCAL_LLM_BASE_URL="http://localhost:1234/v1"
# LOCAL_LLM_API_KEY="local"
# LOCAL_LLM_MODEL="qwen2.5:14b"

# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-5.2"
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-sonnet-4-5"

# Google/Gmail OAuth app credentials (server-side only)
# GOOGLE_CLIENT_ID="..."
# GOOGLE_CLIENT_SECRET="..."
# GOOGLE_REDIRECT_URI="http://localhost:3000/api/integrations/google/callback"

# Required before connecting Gmail accounts. Generate with: openssl rand -base64 32
# TOKEN_ENCRYPTION_KEY="..."

# Optional separate signing secret for short-lived OAuth state payloads.
# OAUTH_STATE_SECRET="..."
