// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ─────────────────────────────────────────────────────────────────────

enum OrganizationPlan {
  free
  pro
  enterprise
}

enum CompanyRelationshipType {
  customer
  vendor
  msp
  property_manager
  contractor
  partner
}

enum CompanySize {
  startup
  smb
  mid
  enterprise
}

enum CompanyStatus {
  prospect
  active
  inactive
  churned
}

enum ContactRole {
  decision_maker
  influencer
  user
  admin
  site_contact
  dispatcher
}

enum ContactStatus {
  active
  inactive
}

enum LeadStage {
  new
  evaluating
  bidding
  submitted
  won
  lost
}

enum TaskStatus {
  todo
  in_progress
  done
  cancelled
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum VendorStatus {
  active
  inactive
  blacklisted
}

enum JobStatus {
  open
  bidding
  awarded
  in_progress
  completed
  cancelled
}

enum JobPriority {
  low
  medium
  high
  urgent
}

enum OutreachChannel {
  email
  phone
  sms
  linkedin
  meeting
  note
  other
}

enum OutreachDirection {
  inbound
  outbound
}

enum OutreachStatus {
  draft
  scheduled
  sent
  delivered
  opened
  replied
  bounced
  failed
  cancelled
}

enum EmailDraftStatus {
  draft
  needs_review
  approved
  rejected
  sent
}

enum EmailDraftMode {
  signal
  fallback
  soft
  partnership
}

enum PartnerCandidateStatus {
  discovered
  researching
  qualified
  contacted
  converted
  rejected
  archived
}

enum PartnershipType {
  subcontractor
  vendor_network
  referral_partner
  field_service_partner
  unknown
}

enum IntegrationProvider {
  openai
  anthropic
  local_openai
  google_gmail
  google_oauth
}

enum IntegrationCredentialKind {
  ai_provider
  oauth_app
  oauth_connection
}

enum IntegrationCredentialStatus {
  configured
  missing_env
  invalid
  connected
  disabled
}

enum AiProviderCallStatus {
  success
  failed
  skipped
}

enum OrganizationMemberRole {
  owner
  admin
  manager
  member
  viewer
}

enum WorkspaceInvitationStatus {
  pending
  accepted
  revoked
  expired
}

// ─── MODELS ────────────────────────────────────────────────────────────────────

model Organization {
  id        String           @id @default(uuid())
  name      String
  slug      String           @unique
  plan      OrganizationPlan @default(free)
  settings  Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  companies              Company[]
  contacts               Contact[]
  leads                  Lead[]
  tasks                  Task[]
  vendors                Vendor[]
  jobs                   Job[]
  outreach               Outreach[]
  emailDrafts            EmailDraft[]
  emailThreads           EmailThread[]
  emailMessages          EmailMessage[]
  workspaceProfile       WorkspaceProfile?
  workspaceAiStrategy    WorkspaceAiStrategy?
  websiteSnapshots       WebsiteSnapshot[]
  websitePages           WebsitePage[]
  agentResearchRuns      AgentResearchRun[]
  partnerCandidates      PartnerCandidate[]
  integrationCredentials IntegrationCredential[]
  gmailConnections       GmailConnection[]
  aiProviderCalls        AiProviderCall[]
  aiUsageBudget          AiUsageBudget?
  members                OrganizationMember[]
  invitations            WorkspaceInvitation[]

  @@map("organizations")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships         OrganizationMember[]
  sessions            UserSession[]
  sentInvitations     WorkspaceInvitation[] @relation("WorkspaceInvitationInviter")
  acceptedInvitations WorkspaceInvitation[] @relation("WorkspaceInvitationAcceptedBy")
  gmailConnections    GmailConnection[]

  @@map("users")
}

model OrganizationMember {
  id             String                 @id @default(uuid())
  organizationId String
  userId         String
  role           OrganizationMemberRole @default(member)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("organization_members")
}

model UserSession {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model WorkspaceInvitation {
  id             String                    @id @default(uuid())
  organizationId String
  email          String
  role           OrganizationMemberRole    @default(member)
  status         WorkspaceInvitationStatus @default(pending)
  tokenHash      String                    @unique
  invitedById    String
  acceptedById   String?
  expiresAt      DateTime
  acceptedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("WorkspaceInvitationInviter", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedBy   User?        @relation("WorkspaceInvitationAcceptedBy", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@unique([organizationId, email, status])
  @@index([organizationId])
  @@index([email])
  @@index([status])
  @@map("workspace_invitations")
}

model Company {
  id               String                  @id @default(uuid())
  organizationId   String
  name             String
  relationshipType CompanyRelationshipType @default(customer)
  domain           String?
  industry         String?
  size             CompanySize?
  status           CompanyStatus           @default(prospect)
  website          String?
  phone            String?
  address          Json?
  metadata         Json?
  deletedAt        DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts          Contact[]
  leads             Lead[]
  vendors           Vendor[]
  jobs              Job[]
  outreach          Outreach[]
  emailDrafts       EmailDraft[]
  emailThreads      EmailThread[]
  websiteSnapshots  WebsiteSnapshot[]
  websitePages      WebsitePage[]
  agentResearchRuns AgentResearchRun[]
  partnerCandidates PartnerCandidate[]

  @@index([organizationId])
  @@index([status])
  @@map("companies")
}

model Contact {
  id             String        @id @default(uuid())
  organizationId String
  companyId      String?
  firstName      String
  lastName       String?
  email          String?
  phone          String?
  title          String?
  role           ContactRole?
  source         String?
  status         ContactStatus @default(active)
  metadata       Json?
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company           Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  leads             Lead[]
  jobs              Job[]
  outreach          Outreach[]
  emailDrafts       EmailDraft[]
  emailThreads      EmailThread[]
  websiteSnapshots  WebsiteSnapshot[]
  websitePages      WebsitePage[]
  agentResearchRuns AgentResearchRun[]
  partnerCandidates PartnerCandidate[]

  @@index([organizationId])
  @@index([companyId])
  @@map("contacts")
}

model Lead {
  id             String    @id @default(uuid())
  organizationId String
  contactId      String?
  companyId      String?
  title          String
  stage          LeadStage @default(new)
  value          Decimal?
  currency       String    @default("USD")
  probability    Int?
  source         String?
  assignedToId   String?
  expectedClose  DateTime?
  metadata       Json?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact           Contact?           @relation(fields: [contactId], references: [id], onDelete: SetNull)
  company           Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  jobs              Job[]
  outreach          Outreach[]
  emailDrafts       EmailDraft[]
  emailThreads      EmailThread[]
  websiteSnapshots  WebsiteSnapshot[]
  websitePages      WebsitePage[]
  agentResearchRuns AgentResearchRun[]
  partnerCandidates PartnerCandidate[]

  @@index([organizationId])
  @@index([contactId])
  @@index([companyId])
  @@index([stage])
  @@map("leads")
}

model Task {
  id             String       @id @default(uuid())
  organizationId String
  title          String
  description    String?
  status         TaskStatus   @default(todo)
  priority       TaskPriority @default(medium)
  dueDate        DateTime?
  completedAt    DateTime?
  assignedToId   String?
  entityType     String?
  entityId       String?
  metadata       Json?
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([entityType, entityId])
  @@index([status])
  @@map("tasks")
}

model Vendor {
  id             String       @id @default(uuid())
  organizationId String
  companyId      String?
  name           String
  category       String?
  contactName    String?
  email          String?
  phone          String?
  website        String?
  status         VendorStatus @default(active)
  rating         Int?
  notes          String?
  metadata       Json?
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  jobs         Job[]

  @@index([organizationId])
  @@index([companyId])
  @@index([status])
  @@map("vendors")
}

model Job {
  id             String      @id @default(uuid())
  organizationId String
  companyId      String?
  contactId      String?
  vendorId       String?
  leadId         String?
  title          String
  description    String?
  status         JobStatus   @default(open)
  priority       JobPriority @default(medium)
  type           String?
  siteAddress    Json?
  postedDate     DateTime?
  dueDate        DateTime?
  bidDeadline    DateTime?
  estimatedValue Decimal?
  assignedToId   String?
  metadata       Json?
  deletedAt      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  vendor       Vendor?      @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  outreach     Outreach[]

  @@index([organizationId])
  @@index([companyId])
  @@index([contactId])
  @@index([vendorId])
  @@index([leadId])
  @@index([status])
  @@map("jobs")
}

model Outreach {
  id             String            @id @default(uuid())
  organizationId String
  companyId      String?
  contactId      String?
  leadId         String?
  jobId          String?
  channel        OutreachChannel   @default(email)
  direction      OutreachDirection @default(outbound)
  status         OutreachStatus    @default(draft)
  subject        String?
  body           String?
  scheduledAt    DateTime?
  sentAt         DateTime?
  deliveredAt    DateTime?
  openedAt       DateTime?
  repliedAt      DateTime?
  metadata       Json?
  deletedAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact      Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead         Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  job          Job?          @relation(fields: [jobId], references: [id], onDelete: SetNull)
  emailDrafts  EmailDraft[]
  emailThreads EmailThread[]

  @@index([organizationId])
  @@index([companyId])
  @@index([contactId])
  @@index([leadId])
  @@index([jobId])
  @@index([channel])
  @@index([status])
  @@index([scheduledAt])
  @@map("outreach")
}

model EmailDraft {
  id                   String           @id @default(uuid())
  organizationId       String
  outreachId           String?
  companyId            String?
  contactId            String?
  leadId               String?
  mode                 EmailDraftMode   @default(signal)
  status               EmailDraftStatus @default(needs_review)
  subject              String
  body                 String
  usedSignal           String?
  verifierDecision     String?
  verifierReason       String?
  verifierEditedBody   String?
  agent2Output         Json?
  agent3Output         Json?
  promptKey            String
  promptSource         String
  verifierPromptKey    String?
  verifierPromptSource String?
  approvedAt           DateTime?
  rejectedAt           DateTime?
  sentAt               DateTime?
  gmailDraftId         String?
  metadata             Json?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  outreach     Outreach?    @relation(fields: [outreachId], references: [id], onDelete: SetNull)
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([outreachId])
  @@index([companyId])
  @@index([contactId])
  @@index([leadId])
  @@index([status])
  @@index([mode])
  @@map("email_drafts")
}

model EmailThread {
  id               String    @id @default(uuid())
  organizationId   String
  companyId        String?
  contactId        String?
  leadId           String?
  outreachId       String?
  provider         String    @default("manual")
  providerThreadId String?
  subject          String
  status           String    @default("open")
  classification   String?
  lastMessageAt    DateTime?
  metadata         Json?
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact      Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead         Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  outreach     Outreach?      @relation(fields: [outreachId], references: [id], onDelete: SetNull)
  messages     EmailMessage[]

  @@unique([organizationId, provider, providerThreadId])
  @@index([organizationId])
  @@index([companyId])
  @@index([contactId])
  @@index([leadId])
  @@index([outreachId])
  @@index([status])
  @@index([classification])
  @@index([lastMessageAt])
  @@map("email_threads")
}

model EmailMessage {
  id                String            @id @default(uuid())
  organizationId    String
  threadId          String
  providerMessageId String?
  direction         OutreachDirection
  fromEmail         String?
  toEmail           String?
  subject           String?
  body              String
  classification    String?
  suggestedSubject  String?
  suggestedBody     String?
  suggestedAt       DateTime?
  suggestionStatus  String?
  sentAt            DateTime?
  receivedAt        DateTime?
  metadata          Json?
  deletedAt         DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  thread       EmailThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([organizationId, providerMessageId])
  @@index([organizationId])
  @@index([threadId])
  @@index([direction])
  @@index([classification])
  @@index([suggestionStatus])
  @@index([receivedAt])
  @@index([sentAt])
  @@map("email_messages")
}

model PartnerCandidate {
  id                       String                 @id @default(uuid())
  organizationId           String
  companyId                String?
  contactId                String?
  leadId                   String?
  name                     String
  website                  String?
  description              String?
  industry                 String?
  relevanceReason          String?
  partnershipType          PartnershipType        @default(unknown)
  status                   PartnerCandidateStatus @default(discovered)
  fitScore                 Float?
  fitReasons               String[]               @default([])
  recommendedOutreachAngle String?
  contactEmails            String[]               @default([])
  contactFormUrl           String?
  source                   String                 @default("manual_partnership_discovery")
  promptKey                String?
  promptSource             String?
  analyzedAt               DateTime?
  convertedAt              DateTime?
  metadata                 Json?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([companyId])
  @@index([contactId])
  @@index([leadId])
  @@index([status])
  @@index([partnershipType])
  @@index([fitScore])
  @@map("partner_candidates")
}

model IntegrationCredential {
  id             String                      @id @default(uuid())
  organizationId String
  provider       IntegrationProvider
  kind           IntegrationCredentialKind
  status         IntegrationCredentialStatus @default(missing_env)
  label          String?
  envKeyName     String?
  envSecretName  String?
  scopes         String[]                    @default([])
  config         Json?
  metadata       Json?
  lastCheckedAt  DateTime?
  connectedAt    DateTime?
  disabledAt     DateTime?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider, kind])
  @@index([organizationId])
  @@index([provider])
  @@index([kind])
  @@index([status])
  @@map("integration_credentials")
}

model GmailConnection {
  id                    String                      @id @default(uuid())
  organizationId        String
  userId                String
  email                 String
  status                IntegrationCredentialStatus @default(connected)
  scopes                String[]                    @default([])
  encryptedAccessToken  String
  encryptedRefreshToken String?
  tokenExpiresAt        DateTime?
  lastSyncedAt          DateTime?
  lastError             String?
  metadata              Json?
  connectedAt           DateTime                    @default(now())
  disconnectedAt        DateTime?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, email])
  @@index([organizationId])
  @@index([userId])
  @@index([email])
  @@index([status])
  @@map("gmail_connections")
}

model AiProviderCall {
  id               String               @id @default(uuid())
  organizationId   String
  provider         IntegrationProvider?
  model            String?
  agent            String
  promptKey        String?
  status           AiProviderCallStatus
  durationMs       Int?
  inputChars       Int?
  outputChars      Int?
  requestTokens    Int?
  responseTokens   Int?
  totalTokens      Int?
  estimatedCostUsd Float?
  error            String?
  metadata         Json?
  createdAt        DateTime             @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([provider])
  @@index([agent])
  @@index([status])
  @@index([createdAt])
  @@map("ai_provider_calls")
}

model AiUsageBudget {
  id                  String   @id @default(uuid())
  organizationId      String   @unique
  enforce             Boolean  @default(false)
  monthlyCallLimit    Int?
  monthlyTokenLimit   Int?
  monthlyCostLimitUsd Float?
  perMinuteCallLimit  Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("ai_usage_budgets")
}

model WorkspaceProfile {
  id                  String   @id @default(uuid())
  organizationId      String   @unique
  businessName        String?
  businessDescription String?
  serviceArea         String?
  industriesServed    String[] @default([])
  serviceSpecialties  String[] @default([])
  preferredTone       String?
  outreachStyle       String?
  preferredCta        String?
  doNotMention        String[] @default([])
  senderName          String?
  senderTitle         String?
  senderPhone         String?
  senderEmail         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("workspace_profiles")
}

model WorkspaceAiStrategy {
  id                         String   @id @default(uuid())
  organizationId             String   @unique
  generatedStrategy          Json?
  selectedTargetCategories   String[] @default([])
  selectedPriorityPainPoints String[] @default([])
  selectedCtaStyle           String?
  guardrails                 Json?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("workspace_ai_strategies")
}

model WebsiteSnapshot {
  id             String   @id @default(uuid())
  organizationId String
  leadId         String
  url            String
  rawText        String
  textLength     Int
  fetchedAt      DateTime @default(now())
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead         Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  pages        WebsitePage[]
  researchRuns AgentResearchRun[]
  company      Company?           @relation(fields: [companyId], references: [id])
  companyId    String?
  contact      Contact?           @relation(fields: [contactId], references: [id])
  contactId    String?

  @@index([organizationId])
  @@index([leadId])
  @@index([fetchedAt])
  @@map("website_snapshots")
}

model WebsitePage {
  id              String   @id @default(uuid())
  organizationId  String
  leadId          String
  snapshotId      String?
  url             String
  pageType        String   @default("home")
  rawText         String
  extractedEmails String[] @default([])
  extractedPhones String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead         Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  snapshot     WebsiteSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  company      Company?         @relation(fields: [companyId], references: [id])
  companyId    String?
  contact      Contact?         @relation(fields: [contactId], references: [id])
  contactId    String?

  @@index([organizationId])
  @@index([leadId])
  @@index([snapshotId])
  @@map("website_pages")
}

model AgentResearchRun {
  id             String   @id @default(uuid())
  organizationId String
  leadId         String
  snapshotId     String?
  agent          String   @default("agent1")
  status         String   @default("completed")
  output         Json
  promptKey      String
  promptSource   String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead         Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  snapshot     WebsiteSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  company      Company?         @relation(fields: [companyId], references: [id])
  companyId    String?
  contact      Contact?         @relation(fields: [contactId], references: [id])
  contactId    String?

  @@index([organizationId])
  @@index([leadId])
  @@index([snapshotId])
  @@index([agent])
  @@map("agent_research_runs")
}
