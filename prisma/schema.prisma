// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ─────────────────────────────────────────────────────────────────────

enum OrganizationPlan {
  free
  pro
  enterprise
}

enum CompanyRelationshipType {
  customer
  vendor
  msp
  property_manager
  contractor
  partner
}

enum CompanySize {
  startup
  smb
  mid
  enterprise
}

enum CompanyStatus {
  prospect
  active
  inactive
  churned
}

enum ContactRole {
  decision_maker
  influencer
  user
  admin
  site_contact
  dispatcher
}

enum ContactStatus {
  active
  inactive
}

enum LeadStage {
  new
  evaluating
  bidding
  submitted
  won
  lost
}

enum TaskStatus {
  todo
  in_progress
  done
  cancelled
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum VendorStatus {
  active
  inactive
  blacklisted
}

enum JobStatus {
  open
  bidding
  awarded
  in_progress
  completed
  cancelled
}

enum JobPriority {
  low
  medium
  high
  urgent
}

enum OutreachChannel {
  email
  phone
  sms
  linkedin
  meeting
  note
  other
}

enum OutreachDirection {
  inbound
  outbound
}

enum OutreachStatus {
  draft
  scheduled
  sent
  delivered
  opened
  replied
  bounced
  failed
  cancelled
}

// ─── MODELS ────────────────────────────────────────────────────────────────────

model Organization {
  id        String           @id @default(uuid())
  name      String
  slug      String           @unique
  plan      OrganizationPlan @default(free)
  settings  Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  companies     Company[]
  contacts      Contact[]
  leads         Lead[]
  tasks         Task[]
  vendors       Vendor[]
  jobs          Job[]
  outreach      Outreach[]
  emailThreads  EmailThread[]
  emailMessages EmailMessage[]

  @@map("organizations")
}

model Company {
  id               String                  @id @default(uuid())
  organizationId   String
  name             String
  relationshipType CompanyRelationshipType @default(customer)
  domain           String?
  industry         String?
  size             CompanySize?
  status           CompanyStatus           @default(prospect)
  website          String?
  phone            String?
  address          Json?
  metadata         Json?
  deletedAt        DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts     Contact[]
  leads        Lead[]
  vendors      Vendor[]
  jobs         Job[]
  outreach     Outreach[]
  emailThreads EmailThread[]

  @@index([organizationId])
  @@index([status])
  @@map("companies")
}

model Contact {
  id             String        @id @default(uuid())
  organizationId String
  companyId      String?
  firstName      String
  lastName       String?
  email          String?
  phone          String?
  title          String?
  role           ContactRole?
  source         String?
  status         ContactStatus @default(active)
  metadata       Json?
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  leads        Lead[]
  jobs         Job[]
  outreach     Outreach[]
  emailThreads EmailThread[]

  @@index([organizationId])
  @@index([companyId])
  @@map("contacts")
}

model Lead {
  id             String    @id @default(uuid())
  organizationId String
  contactId      String?
  companyId      String?
  title          String
  stage          LeadStage @default(new)
  value          Decimal?
  currency       String    @default("USD")
  probability    Int?
  source         String?
  assignedToId   String?
  expectedClose  DateTime?
  metadata       Json?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  company      Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  jobs         Job[]
  outreach     Outreach[]
  emailThreads EmailThread[]

  @@index([organizationId])
  @@index([contactId])
  @@index([companyId])
  @@index([stage])
  @@map("leads")
}

model Task {
  id             String       @id @default(uuid())
  organizationId String
  title          String
  description    String?
  status         TaskStatus   @default(todo)
  priority       TaskPriority @default(medium)
  dueDate        DateTime?
  completedAt    DateTime?
  assignedToId   String?
  entityType     String?
  entityId       String?
  metadata       Json?
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([entityType, entityId])
  @@index([status])
  @@map("tasks")
}

model Vendor {
  id             String       @id @default(uuid())
  organizationId String
  companyId      String?
  name           String
  category       String?
  contactName    String?
  email          String?
  phone          String?
  website        String?
  status         VendorStatus @default(active)
  rating         Int?
  notes          String?
  metadata       Json?
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  jobs         Job[]

  @@index([organizationId])
  @@index([companyId])
  @@index([status])
  @@map("vendors")
}

model Job {
  id             String      @id @default(uuid())
  organizationId String
  companyId      String?
  contactId      String?
  vendorId       String?
  leadId         String?
  title          String
  description    String?
  status         JobStatus   @default(open)
  priority       JobPriority @default(medium)
  type           String?
  siteAddress    Json?
  postedDate     DateTime?
  dueDate        DateTime?
  bidDeadline    DateTime?
  estimatedValue Decimal?
  assignedToId   String?
  metadata       Json?
  deletedAt      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  vendor       Vendor?      @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  outreach     Outreach[]

  @@index([organizationId])
  @@index([companyId])
  @@index([contactId])
  @@index([vendorId])
  @@index([leadId])
  @@index([status])
  @@map("jobs")
}

model Outreach {
  id             String            @id @default(uuid())
  organizationId String
  companyId      String?
  contactId      String?
  leadId         String?
  jobId          String?
  channel        OutreachChannel   @default(email)
  direction      OutreachDirection @default(outbound)
  status         OutreachStatus    @default(draft)
  subject        String?
  body           String?
  scheduledAt    DateTime?
  sentAt         DateTime?
  deliveredAt    DateTime?
  openedAt       DateTime?
  repliedAt      DateTime?
  metadata       Json?
  deletedAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact      Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead         Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  job          Job?          @relation(fields: [jobId], references: [id], onDelete: SetNull)
  emailThreads EmailThread[]

  @@index([organizationId])
  @@index([companyId])
  @@index([contactId])
  @@index([leadId])
  @@index([jobId])
  @@index([channel])
  @@index([status])
  @@index([scheduledAt])
  @@map("outreach")
}

model EmailThread {
  id               String    @id @default(uuid())
  organizationId   String
  companyId        String?
  contactId        String?
  leadId           String?
  outreachId       String?
  provider         String    @default("manual")
  providerThreadId String?
  subject          String
  status           String    @default("open")
  classification   String?
  lastMessageAt    DateTime?
  metadata         Json?
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact      Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead         Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  outreach     Outreach?      @relation(fields: [outreachId], references: [id], onDelete: SetNull)
  messages     EmailMessage[]

  @@index([organizationId])
  @@index([companyId])
  @@index([contactId])
  @@index([leadId])
  @@index([outreachId])
  @@index([status])
  @@index([classification])
  @@index([lastMessageAt])
  @@map("email_threads")
}

model EmailMessage {
  id                String            @id @default(uuid())
  organizationId    String
  threadId          String
  providerMessageId String?
  direction         OutreachDirection
  fromEmail         String?
  toEmail           String?
  subject           String?
  body              String
  classification    String?
  suggestedSubject  String?
  suggestedBody     String?
  suggestedAt       DateTime?
  sentAt            DateTime?
  receivedAt        DateTime?
  metadata          Json?
  deletedAt         DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  thread       EmailThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([threadId])
  @@index([direction])
  @@index([classification])
  @@index([receivedAt])
  @@index([sentAt])
  @@map("email_messages")
}
